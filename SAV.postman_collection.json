            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Agência Guarapari\",\n  \"cnpj\": \"11.222.333/0001-44\",\n  \"endereco\": \"Rua das Praias, 200, Guarapari\",\n  \"telefone\": \"(27) 3344-5566\",\n  \"status\": \"Ativa\",\n  \"limiteDiasDesconto\": 5,\n  \"percentualDesconto\": 10.00\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/agencias", "host": ["{{baseUrl}}"], "path": ["agencias"] }
