            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Agência Cachoeiro Atualizada\",\n  \"status\": \"Ativa\",\n  \"limiteDiasDesconto\": 4,\n  \"percentualDesconto\": 12.00\n}", "options": { "raw": { "language": "json" } } },
